# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://daitaview:daitaview@db:5432/daitaview

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Auth mode: local | oidc | saml
# local = username/password only (default)
# oidc  = OpenID Connect (Google, Okta, Azure AD)
# saml  = enterprise SAML
AUTH_MODE=local

# SSO — only required when AUTH_MODE=oidc or AUTH_MODE=saml
SSO_PROVIDER_URL=https://your-provider.example.com
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret
SSO_REDIRECT_URI=http://localhost:8000/auth/sso/callback

# Super admin break-glass account (seeded on first startup)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-immediately

# Execution service (internal Docker network)
EXECUTION_SERVICE_URL=http://execution:8001

# Vector store
VECTOR_STORE_PATH=/app/vector_store

# File uploads
UPLOADS_PATH=/app/uploads
KNOWLEDGE_PATH=/app/knowledge

# Execution limits
EXECUTION_TIMEOUT_SECONDS=30
EXECUTION_MEMORY_LIMIT_MB=512
MAX_UPLOAD_SIZE_MB=500
